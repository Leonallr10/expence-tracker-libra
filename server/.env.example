PORT=5000
# Use mongodb+srv://... if SRV DNS works on your network.
# If you see "querySrv ECONNREFUSED", use the standard URI from Atlas:
# Connect → Drivers → copy "Standard connection string" (mongodb://...)
MONGO_URI=mongodb://<user>:<pass>@cluster-shard-00-00.mongodb.net:27017,cluster-shard-00-01.mongodb.net:27017,cluster-shard-00-02.mongodb.net:27017/expenses?ssl=true&replicaSet=atlas-xxxxx-shard-0&authSource=admin
JWT_SECRET=your_secret_key
# Frontend URL(s) allowed by CORS (comma-separated for multiple)
CLIENT_URL=https://expence-tracker-libra.vercel.app
